SCAN_MODE=filesystem  # filesystem, git, staged
ENTROPY_ENABLED=true
ENTROPY_THRESHOLD=4.5
MASK_FINDINGS=true
FAIL_ON_SEVERITY=high  # low, medium, high, critical
POLICY_PROFILE=default  # developer, ci, strict
IGNORED_PATHS=".git,node_modules,vendor,*.min.js"
OUTPUT_DIR=./scan-results
REPORT_VERBOSITY=standard
SUPPRESSION_FILE=.k1n-suppressions.yaml
