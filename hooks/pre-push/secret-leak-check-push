#!/usr/bin/env bash
# =============================================================================
# secret-leak-sentinel — Pre-push Hook
# =============================================================================
# Scans commits that are about to be pushed for secrets — catches anything that
# slipped past the pre-commit hook (e.g., --no-verify commits, CI-generated
# commits, or direct pushes from tooling).
#
# Unlike the pre-commit hook which scans staged files, the pre-push hook scans
# the full diff of commits that are new relative to the remote.
#
# Installation:
#   cp hooks/pre-push/secret-leak-check-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# Configuration (read from environment):
#   SECRET_LEAK_FAIL_ON_SEVERITY   - Minimum severity to block push (default: high)
#   SECRET_LEAK_ENTROPY_ENABLED    - Enable entropy detection (default: true)
#   SECRET_LEAK_SCAN_DEPTH         - Max commits to scan in a push batch (default: 50)
#
# The hook reads from stdin (format: <local_ref> <local_sha1> <remote_ref> <remote_sha1>)
# as required by the git pre-push hook specification.
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

FAIL_ON_SEVERITY="${SECRET_LEAK_FAIL_ON_SEVERITY:-high}"
ENTROPY_ENABLED="${SECRET_LEAK_ENTROPY_ENABLED:-true}"
SCAN_DEPTH="${SECRET_LEAK_SCAN_DEPTH:-50}"
ZERO_SHA="0000000000000000000000000000000000000000"

# Check that secret-leak-sentinel is installed
if ! command -v secret-leak-sentinel &> /dev/null; then
    echo -e "${YELLOW}[secret-leak-sentinel] Warning: secret-leak-sentinel not in PATH — skipping push scan.${NC}"
    exit 0
fi

echo -e "${BOLD}[secret-leak-sentinel] Pre-push secret scan starting...${NC}"
echo "  Fail on severity: ${FAIL_ON_SEVERITY}"
echo "  Entropy:          ${ENTROPY_ENABLED}"
echo "  Max commits:      ${SCAN_DEPTH}"
echo ""

FOUND_SECRETS=0

# Read the push refs from stdin
while read -r local_ref local_sha remote_ref remote_sha; do
    # Deletion push — nothing to scan
    if [ "${local_sha}" = "${ZERO_SHA}" ]; then
        continue
    fi

    # New branch push (no remote SHA yet) — scan the commit batch reachable
    # from the ref Git is actually pushing, not whatever HEAD happens to be.
    if [ "${remote_sha}" = "${ZERO_SHA}" ]; then
        COMMITS=$(git log --pretty=format:"%H" -n "${SCAN_DEPTH}" "${local_sha}" 2>/dev/null || true)
    else
        COMMITS=$(git log --pretty=format:"%H" -n "${SCAN_DEPTH}" "${remote_sha}..${local_sha}" 2>/dev/null || true)
    fi

    if [ -z "${COMMITS}" ]; then
        continue
    fi

    COMMIT_COUNT=$(echo "${COMMITS}" | wc -l | tr -d ' ')
    echo "  Scanning ${COMMIT_COUNT} commit(s) in ${local_ref} → ${remote_ref}"

    for COMMIT in ${COMMITS}; do
        # Generate the diff for this commit (staged content only)
        DIFF=$(git show --stat --patch --no-color "${COMMIT}" 2>/dev/null || true)

        if [ -z "${DIFF}" ]; then
            continue
        fi

        # Write diff to a temp file for scanning
        TMPFILE=$(mktemp /tmp/secret-leak-push-scan-XXXXXX.diff)
        echo "${DIFF}" > "${TMPFILE}"

        SCAN_CMD=(
            secret-leak-sentinel
            --fail-on "${FAIL_ON_SEVERITY}"
        )

        if [ "${ENTROPY_ENABLED}" = "true" ]; then
            SCAN_CMD+=(--entropy)
        else
            SCAN_CMD+=(--no-entropy)
        fi

        SCAN_CMD+=(
            scan-file
            --patch-mode
            "${TMPFILE}"
        )

        set +e
        "${SCAN_CMD[@]}"
        SCAN_EXIT="${?}"
        set -e

        rm -f "${TMPFILE}"

        if [ "${SCAN_EXIT}" -eq 1 ]; then
            FOUND_SECRETS=1
            echo -e "${RED}  FAIL: Potential secret detected in commit ${COMMIT:0:8}${NC}"
            echo ""
        fi
    done
done

if [ "${FOUND_SECRETS}" -eq 1 ]; then
    echo ""
    echo -e "${RED}${BOLD}[secret-leak-sentinel] PUSH BLOCKED — Potential secrets detected in commits.${NC}"
    echo ""
    echo "  Steps to resolve:"
    echo "  1. Identify the finding from the output above"
    echo "  2. If it is a real secret:"
    echo "     a. Rotate the secret immediately"
    echo "     b. Remove it from git history: git rebase -i or BFG Repo Cleaner"
    echo "     c. Force-push only after history is clean (coordinate with team)"
    echo "  3. If it is a false positive:"
    echo "     a. Add a suppression entry to .secret-leak-suppressions.yaml"
    echo "     b. Document the reason clearly"
    echo ""
    echo "  Do NOT bypass this check without confirming no real secrets are present."
    echo ""
    exit 1
fi

echo -e "${GREEN}[secret-leak-sentinel] No secrets detected. Push proceeding.${NC}"
exit 0
