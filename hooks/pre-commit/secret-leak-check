#!/usr/bin/env bash
# =============================================================================
# secret-leak-sentinel — Pre-commit Hook
# =============================================================================
# Scans staged files for potential secrets before allowing a commit.
# Blocks the commit if any finding meets or exceeds the configured severity.
#
# Installation:
#   cp hooks/pre-commit/secret-leak-check .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Configuration (read from environment or .env file in repo root):
#   SECRET_LEAK_FAIL_ON_SEVERITY   - Minimum severity to block commit (default: high)
#   SECRET_LEAK_ENTROPY_ENABLED    - Enable entropy detection (default: true)
#   SECRET_LEAK_ENTROPY_THRESHOLD  - Shannon entropy threshold (default: 4.5)
#   SECRET_LEAK_POLICY_PROFILE     - Policy profile name (default: default)
#
# To bypass in an emergency (use with extreme caution):
#   git commit --no-verify -m "message"
#   # Note: --no-verify skips ALL hooks, not just this one.
# =============================================================================

set -euo pipefail

# ── Colour output ─────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'  # No colour

# ── Load .env if present ──────────────────────────────────────────────────────
if [ -f ".env" ]; then
    # Source only lines that look like variable assignments; ignore comments and blanks
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^[[:space:]]*# ]] && continue  # Skip comments
        [[ -z "$key" ]] && continue                  # Skip blank lines
        # Strip inline comments from value
        value="${value%%#*}"
        value="${value%"${value##*[![:space:]]}"}"  # Trim trailing whitespace
        export "${key}=${value}"
    done < <(grep -E '^[A-Z_]+=.*' .env 2>/dev/null || true)
fi

# ── Configuration ─────────────────────────────────────────────────────────────
FAIL_ON_SEVERITY="${SECRET_LEAK_FAIL_ON_SEVERITY:-high}"
ENTROPY_ENABLED="${SECRET_LEAK_ENTROPY_ENABLED:-true}"
POLICY_PROFILE="${SECRET_LEAK_POLICY_PROFILE:-default}"

# ── Check that secret-leak-sentinel is installed ─────────────────────────────────────
if ! command -v secret-leak-sentinel &> /dev/null; then
    echo -e "${YELLOW}[secret-leak-sentinel] Warning: secret-leak-sentinel is not in PATH.${NC}"
    echo "  Install it with: pip install secret-leak-sentinel"
    echo "  Or activate your virtual environment: source .venv/bin/activate"
    echo ""
    echo "  Skipping secret scan. To enforce scanning, install secret-leak-sentinel."
    exit 0  # Exit 0 so the commit is not blocked by a missing tool
fi

# ── Run the staged-file scan ──────────────────────────────────────────────────
echo -e "${BOLD}[secret-leak-sentinel] Scanning staged files for secrets...${NC}"
echo "  Policy:            ${POLICY_PROFILE}"
echo "  Fail on severity:  ${FAIL_ON_SEVERITY}"
echo "  Entropy detection: ${ENTROPY_ENABLED}"
echo ""

# Build the scan command
SCAN_CMD=(
    secret-leak-sentinel
    --fail-on "${FAIL_ON_SEVERITY}"
    --policy-profile "${POLICY_PROFILE}"
)

if [ "${ENTROPY_ENABLED}" = "true" ]; then
    SCAN_CMD+=(--entropy)
else
    SCAN_CMD+=(--no-entropy)
fi

SCAN_CMD+=(scan-staged)

# Execute the scan and capture the exit code
set +e
"${SCAN_CMD[@]}"
SCAN_EXIT_CODE=$?
set -e

# ── Handle the scan result ───────────────────────────────────────────────────
if [ "${SCAN_EXIT_CODE}" -eq 0 ]; then
    echo -e "${GREEN}[secret-leak-sentinel] No secrets detected. Proceeding with commit.${NC}"
    exit 0

elif [ "${SCAN_EXIT_CODE}" -eq 1 ]; then
    echo ""
    echo -e "${RED}${BOLD}[secret-leak-sentinel] COMMIT BLOCKED — Potential secrets detected.${NC}"
    echo ""
    echo "  Review the findings above. If they are false positives, you have two options:"
    echo ""
    echo "  1. Add a suppression entry to .secret-leak-suppressions.yaml:"
    echo "     suppressions:"
    echo "       - file: \"path/to/file\""
    echo "         reason: \"Test fixture — not a real credential\""
    echo ""
    echo "  2. Rotate the secret immediately, then remove it from the staged file."
    echo ""
    echo "  Do NOT use --no-verify unless you have confirmed there are no real secrets."
    echo ""
    exit 1

else
    echo -e "${YELLOW}[secret-leak-sentinel] Scan returned an unexpected exit code: ${SCAN_EXIT_CODE}.${NC}"
    echo "  The commit will proceed. Investigate the scan output above."
    exit 0
fi
